import { db } from './config/firebase.js'; // Adjust paths based on your runtime environment structure
import { collection, getDocs, query, where } from 'firebase/firestore';

/**
 * OnyxStack Labs - Dynamic Enterprise XML Sitemap Generator Pipeline
 * Optimized for Traditional SEO & Generative AI Search Engine Crawlers (GEO / LLMO)
 */
export async function generateSitemap() {
  const BASE_URL = 'https://onyxstacklabs.com';
  const currentDate = new Date().toISOString().split('T')[0];

  // 1. Immutable Premium Enterprise Static Routes Definition Matrix
  const staticRoutes = [
    { path: '/', changefreq: 'weekly', priority: '1.0' },
    { path: '/about', changefreq: 'monthly', priority: '0.9' },
    { path: '/services', changefreq: 'monthly', priority: '0.9' },
    { path: '/portfolio', changefreq: 'monthly', priority: '0.8' },
    { path: '/pricing', changefreq: 'monthly', priority: '0.8' },
    { path: '/careers', changefreq: 'weekly', priority: '0.7' },
    { path: '/contact', changefreq: 'monthly', priority: '0.8' },
    { path: '/privacy-policy', changefreq: 'yearly', priority: '0.3' },
    { path: '/terms-conditions', changefreq: 'yearly', priority: '0.3' },
    { path: '/cookie-policy', changefreq: 'yearly', priority: '0.3' },
    { path: '/thankyou', changefreq: 'monthly', priority: '0.5' },
    { path: '/blog', changefreq: 'daily', priority: '0.9' }
  ];

  let xmlUrlNodes = '';

  // Process static inventory nodes into XML wrappers
  staticRoutes.forEach(route => {
    xmlUrlNodes += `
  <url>
    <loc>${BASE_URL}${route.path}</loc>
    <lastmod>${currentDate}</lastmod>
    <changefreq>${route.changefreq}</changefreq>
    <priority>${route.priority}</priority>
  </url>`;
  });

  // 2. Fetch Context-Aware Dynamic Deep Intelligence Vectors from Google Cloud Firestore
  try {
    const blogCollectionRef = collection(db, 'blogs');
    // Strict enforcement parameter: Extract entries mapped strictly to status structural boundary node "LIVE"
    const liveBlogsQuery = query(blogCollectionRef, where('status', '==', 'LIVE'));
    const querySnapshot = await getDocs(liveBlogsQuery);

    querySnapshot.forEach(doc => {
      const blogData = doc.data();
      const slug = blogData.slug;
      
      // Secondary fallback parameter verification layer: timestamp parsing strategy
      let lastModDate = currentDate;
      const rawDate = blogData.updatedAt || blogData.createdAt;
      
      if (rawDate) {
        try {
          const dateObj = rawDate.toDate ? rawDate.toDate() : new Date(rawDate);
          if (!isNaN(dateObj.getTime())) {
            lastModDate = dateObj.toISOString().split('T')[0];
          }
        } catch (e) {
          lastModDate = currentDate;
        }
      }

      if (slug) {
        xmlUrlNodes += `
  <url>
    <loc>${BASE_URL}/blog/${slug}</loc>
    <lastmod>${lastModDate}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>`;
      }
    });
  } catch (firestoreError) {
    console.error("Fatal Dynamic Pipeline Transmission Drop: Unable to compile Firestore data sync layers.", firestoreError);
    // Silent failover implementation matrix: allow standard payload export even if content cluster fails
  }

  // 3. Assemble complete standards-compliant dynamic XML structural map string (Extended for AI/GEO schema validation)
  const completeSitemapXml = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">${xmlUrlNodes}
</urlset>`;

  return completeSitemapXml;
}
